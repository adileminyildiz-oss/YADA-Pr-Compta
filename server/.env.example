# Copiez ce fichier en .env et collez les VRAIES valeurs depuis le dialogue
# "Connect" du tableau de bord Supabase. NE COMMITTEZ JAMAIS .env (ni la clé secrète).
SUPABASE_URL=https://VOTRE-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=VOTRE_CLE_PUBLISHABLE_OU_ANON
SUPABASE_SECRET_KEY=VOTRE_CLE_SECRETE_SERVICE_ROLE   # serveur uniquement — JAMAIS côté client
SUPABASE_JWKS_URL=https://VOTRE-REF.supabase.co/auth/v1/.well-known/jwks.json
# Port du serveur local (adaptateur Node) ; mettre YADA_LOCAL_SERVER=0 pour désactiver l'adaptateur.
PORT=8787
